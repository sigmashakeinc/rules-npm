# npm_write_secrets.rules — Block credential exposure in npm config files.
# Technology: npm | Capability: write
# Covers: .npmrc authToken, password fields, custom registry redirects.

rule no-npmrc-authtoken {
  enabled true
  priority 95
  severity error
  DENY write
  IF path EQUALS ".npmrc" AND content LINE_REGEX "_authToken\\s*="
  OR path ENDS_WITH "/.npmrc" AND content LINE_REGEX "_authToken\\s*="
  OR path GLOB "**/.npmrc" AND content LINE_REGEX "_authToken\\s*="
  MESSAGE "Hardcoded npm auth token detected in .npmrc. Tokens committed to source control expose registry credentials to anyone with repo access. Use environment variable substitution instead: //registry.npmjs.org/:_authToken=${NPM_TOKEN}"
}

rule no-npmrc-password {
  enabled true
  priority 95
  severity error
  DENY write
  IF path EQUALS ".npmrc" AND content LINE_REGEX "_password\\s*="
  OR path GLOB "**/.npmrc" AND content LINE_REGEX "_password\\s*="
  MESSAGE "Plaintext password detected in .npmrc. Store credentials using 'npm login' or environment variables, never as a plaintext value in source control."
}

rule ask-npmrc-custom-registry {
  enabled true
  priority 85
  severity warning
  LOG write
  IF path EQUALS ".npmrc" AND content LINE_REGEX "^registry\\s*="
  OR path GLOB "**/.npmrc" AND content LINE_REGEX "^registry\\s*="
  MESSAGE "Custom npm registry detected in .npmrc. Redirecting to a non-official registry can enable dependency confusion attacks if the private registry does not prevent public package shadowing."
}
