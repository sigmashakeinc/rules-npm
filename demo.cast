[34.736619, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[4A  To publish, you have two options:                                                                                                                                              \r\u001b[1B   \r\u001b[2B\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m                                                         \r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
[35.125878, "o", "\u001b]0;⠐ Publish package to npm\u0007"]
[35.184172, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[4A  1. \u001b[1mUse a different package name\u001b[22m - Change the name in \u001b[38;5;153mpackage.json\u001b[39m to something unique (e.g., \u001b[38;5;153mdemo-pkg-sigmashake\u001b[39m, \u001b[38;5;153m@sigmashake/demo-pkg\u001b[39m)                                        \r\u001b[1B   \r\u001b[2B\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m                                                         \r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
[35.246079, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[2C\u001b[5A2.\u001b[1C\u001b[1mUse a scoped package\u001b[1C\u001b[22m-\u001b[1CChange\u001b[1Cto\u001b[1C\u001b[38;5;153m@sigmashake/demo-pkg\u001b[1C\u001b[39mto\u001b[1Cpublish\u001b[1Cunder\u001b[1Cyour\u001b[1Cnamespace\r\u001b[1B                                                                                                                                                                                 \r\u001b[1B\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\r\u001b[1B\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m                                                                                                                                                                              \r\u001b[1B\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
[35.264022, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[4A  Which would you prefer?                                                                                                                                                        \r\u001b[1B   \r\u001b[1B\u001b[38;5;174m*\u001b[39m \u001b[38;5;216mW\u001b[38;5;174mandering… \u001b[39m                                                                                                                                                                    \r\u001b[2C\u001b[1B                                                          \r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m\r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
[35.294103, "o", "\u001b]0;✳ Publish package to npm\u0007"]
